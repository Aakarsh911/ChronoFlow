generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  name           String?
  googleId       String?         @unique
  image          String?
  accessToken    String?
  refreshToken   String?
  createdAt      DateTime        @default(now())
  onboarding     Boolean         @default(false)
  aiConsent      Boolean         @default(false)
  aiConsentDate  DateTime?
  integrations   Integration[]
  tasks          Task[]
  taskEvents     TaskEvent[]
  calendarEvents CalendarEvent[]
  calendarSyncs  CalendarSync[]
}

// Public waitlist queue. Anyone who fills out the /waitlist form lands here.
// This is informational only — being on the waitlist does NOT grant login.
model WaitlistSignup {
  id        String   @id @default(uuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Explicit allowlist of emails that may complete sign-in. Managed by admins
// from /admin/waitlist (or by direct SQL). Checked in the NextAuth signIn
// callback alongside the ADMIN_EMAILS env var.
model InvitedEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  invitedAt DateTime @default(now())
  invitedBy String?
  notes     String?

  @@index([invitedAt])
}

// First-party visit tracking for the public marketing pages (waitlist + any
// future top-of-funnel surfaces). Fired client-side from a tiny tracker that
// reads UTM params and document.referrer; the server skips writes when the
// `cf_no_track` cookie is set or when a known bot User-Agent is detected.
//
// IPs are not stored raw — only a daily-rotating SHA-256 hash, so we can do
// rough unique-visitor counts without persisting PII.
model PageVisit {
  id          String   @id @default(uuid())
  path        String   // e.g. "/waitlist"
  source      String?  // utm_source (e.g. "reddit")
  medium      String?  // utm_medium (e.g. "social")
  campaign    String?  // utm_campaign (e.g. "saas-launch")
  referrer    String?  // document.referrer host (e.g. "reddit.com")
  ipHash      String?  // sha256(ip + daily_salt) — rotates every day
  userAgent   String?  // truncated to 256 chars
  country     String?  // from x-vercel-ip-country if present
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([source])
  @@index([path, createdAt])
}

enum Provider {
  GOOGLE
  MICROSOFT
  JIRA
}

model Integration {
  id           String    @id @default(uuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  provider     Provider
  accessToken  String?
  refreshToken String?
  scope        String?
  expiresAt    DateTime?
  accountId    String?
  data         Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
}

model Task {
  id           String    @id @default(uuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  title        String
  description  String?
  status       String    @default("todo")
  source       String
  sourceId     String?
  sourceData   Json?
  url          String?
  priority     String?
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  events       TaskEvent[]

  @@index([userId])
  @@unique([userId, source, sourceId])
}

model TaskEvent {
  id        String   @id @default(uuid())
  type      String
  payload   Json?
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([userId])
}

// Calendar Event Types
enum EventType {
  MEETING        // External meetings with attendees (cannot be moved)
  TASK           // Work tasks that can be rescheduled
  FOCUS_TIME     // Dedicated focus blocks (can be moved)
  PERSONAL       // Personal events
}

enum EventSource {
  GOOGLE
  MICROSOFT
  CHRONOFLOW     // Events created directly in ChronoFlow
}

enum SyncStatus {
  SYNCED         // Successfully synced with external calendar
  PENDING        // Waiting to be pushed to external calendar
  CONFLICT       // Conflict detected between local and external
  ERROR          // Sync failed
}

// Calendar Events - stores all calendar events from all sources
model CalendarEvent {
  id                String      @id @default(uuid())
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  
  // Event Details
  title             String
  description       String?
  startTime         DateTime
  endTime           DateTime
  isAllDay          Boolean     @default(false)
  location          String?
  timeZone          String?     @default("UTC")
  
  // Attendees and Meeting Info
  attendees         Json?       // Array of attendee objects
  organizerEmail    String?
  meetingUrl        String?
  htmlLink          String?
  
  // Classification
  eventType         EventType   @default(PERSONAL)
  isManaged         Boolean     @default(false)  // Can the algorithm move this event?
  
  // External Calendar Sync
  source            EventSource
  sourceId          String?     // External calendar event ID (Google/Microsoft)
  sourceCalendarId  String?     // Which calendar it belongs to
  sourceData        Json?       // Full external event object for round-trip sync
  
  // Optional Task Linkage (for task-based events)
  taskId            String?
  
  // Sync Metadata
  lastSyncedAt      DateTime?
  modifiedLocally   Boolean     @default(false)  // Has the algorithm or user modified this?
  syncStatus        SyncStatus  @default(SYNCED)
  syncError         String?
  
  // Timestamps
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
  @@index([userId, startTime])
  @@index([userId, eventType, isManaged])
  @@index([source, sourceId])
  @@index([syncStatus, modifiedLocally])
  @@unique([userId, source, sourceId])
}

// Calendar Sync State - tracks sync status per calendar per user
model CalendarSync {
  id                String      @id @default(uuid())
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  
  // Calendar Info
  source            EventSource
  calendarId        String      // External calendar ID
  calendarName      String?
  
  // Sync State
  lastSyncedAt      DateTime?
  lastSuccessfulSync DateTime?
  syncEnabled       Boolean     @default(true)
  syncFrequency     Int         @default(300)   // Sync frequency in seconds (default: 5 min)
  
  // Error Tracking
  lastSyncError     String?
  consecutiveErrors Int         @default(0)
  
  // Sync Token (for incremental sync)
  syncToken         String?     // Used for Google Calendar incremental sync
  deltaLink         String?     // Used for Microsoft Graph incremental sync
  
  // Timestamps
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([userId, source, calendarId])
  @@index([userId, source])
  @@index([syncEnabled, lastSyncedAt])
}
