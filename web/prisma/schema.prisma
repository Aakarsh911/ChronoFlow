// Prisma schema for Postgres

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  googleId     String?       @unique
  image        String?
  accessToken  String?
  refreshToken String?
  createdAt    DateTime      @default(now())
  onboarding   Boolean       @default(false)
  integrations Integration[]
  tasks        Task[]
  taskEvents   TaskEvent[]
}

model Integration {
  id           String    @id @default(uuid())
  userId       String
  provider     String // e.g. "JIRA", "SLACK", "TEAMS", "GOOGLE"
  accessToken  String?
  refreshToken String?
  scope        String?
  expiresAt    DateTime?
  accountId    String?
  data         Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Task {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  status      String    @default("To Do") // e.g., 'To Do', 'In Progress', 'Done'
  source      String // e.g., 'JIRA', 'SLACK', 'MANUAL'
  sourceId    String? // The ID from the original system
  sourceData  Json? // Original payload from the source
  url         String?
  priority    String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  events TaskEvent[]

  @@unique([userId, source, sourceId])
  @@index([userId])
}

model TaskEvent {
  id        String   @id @default(uuid())
  type      String // e.g., 'CREATED', 'STATUS_CHANGED'
  payload   Json?
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}
